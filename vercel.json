{
  "version": 2,
  "builds": [
    {
      "src": "public/**",
      "use": "@vercel/static"
    },
    {
      "src": "api/factcheck.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/factcheck",
      "dest": "/api/factcheck.py"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.html"
    }
  ]
}
